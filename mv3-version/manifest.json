{
  "manifest_version": 3,
  "name": "Febbox Token Extractor",
  "version": "1.0.0",
  "description": "Extracts your Febbox session token from the ui cookie and displays it for easy copying. No data is sent anywhere.",
  "permissions": [
    "cookies"
  ],
  "host_permissions": [
    "https://febbox.com/*",
    "https://www.febbox.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Febbox Token Extractor",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "febbox-token-extractor@local",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ],
        "optional": []
      }
    }
  }
}